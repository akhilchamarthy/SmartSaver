{
    "manifest_version": 3,
    "name": "SmartSaver",
    "version": "0.0.2",
    "description": "Add offers to your credit card with the click of a button",
    "permissions": [
      "scripting",
      "tabs",
      "storage",
      "notifications",
      "activeTab"
    ],
    "host_permissions": ["*://*/*"],
    "background": {
      "service_worker": "background.js"
    },
    "content_scripts": [
      {
        "matches": ["*://*/*"],
        "js": ["content_script_checkout.js"],
        "run_at": "document_end"
      }
    ],
    "action": {
      "default_popup": "popup.html"
    },
    "icons": {
      "16": "saver.png"
    },
    "web_accessible_resources": [
      {
        "resources": ["default_benefits.json"],
        "matches": ["<all_urls>"]
      }
    ]
}